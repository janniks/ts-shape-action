{
  "name": "ts-shape-action",
  "version": "0.1.0",
  "description": "GitHub Action to compute and diff the public API surface of TypeScript npm workspace packages",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ts-shape": "dist/index.js",
    "ts-shape-diff": "dist/diff-cli.js"
  },
  "scripts": {
    "build": "tsc --noEmit && npm run bundle",
    "bundle": "esbuild src/index.ts src/diff-cli.ts --bundle --platform=node --target=node18 --format=esm --outdir=dist --packages=external",
    "start": "node dist/index.js",
    "diff": "node dist/diff-cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "typescript",
    "api",
    "surface",
    "github-action",
    "monorepo",
    "npm-workspaces"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "glob": "^10.3.10",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.27.4",
    "vitest": "^4.0.18"
  }
}
